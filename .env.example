# media-mcp configuration — copy to .env and fill in.
# .env is gitignored. All values are read from the environment at import time.

# ── Mode ────────────────────────────────────────────────────────────
# safe = search/request/status only; full = + direct Radarr/Sonarr/qBit/Prowlarr/Jellyfin control
MEDIA_MCP_MODE=safe

# ── Jellyseerr (required, all modes) ────────────────────────────────
JELLYSEERR_URL=http://localhost:5055
JELLYSEERR_API_KEY=

# ── Radarr / Sonarr (progress in safe, full control in full) ────────
RADARR_URL=http://localhost:7878
RADARR_API_KEY=
SONARR_URL=http://localhost:8989
SONARR_API_KEY=

# ── Jellyfin (availability + library scan) ──────────────────────────
JELLYFIN_URL=http://localhost:8096
JELLYFIN_API_KEY=

# ── Prowlarr (full mode: release search/grab) ───────────────────────
PROWLARR_URL=http://localhost:9696
PROWLARR_API_KEY=

# ── qBittorrent (full mode: grab/route/tag) ─────────────────────────
QBIT_URL=http://localhost:8081
QBIT_USER=
QBIT_PASS=

# ── Navidrome (music tools + discovery/) ────────────────────────────
NAVIDROME_URL=http://localhost:4533
NAVIDROME_USER=
NAVIDROME_PASS=

# ── Audiobookshelf (audiobook/ebook importer) ───────────────────────
ABS_URL=http://localhost:13378
ABS_API_KEY=

# ── Telegram notifications (optional; silent if unset) ──────────────
# Default bot/chat used for "ready" notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Chat the MCP server tags onto grabs so the importer notifies the requester.
NOTIFY_CHAT_ID=
# Per-requester routing: set NOTIFY_TOKEN_<chat_id>=<bot_token> to notify a
# specific chat via a specific bot (e.g. NOTIFY_TOKEN_123456=abc:def).

# ── Webhook receiver (Jellyseerr → Telegram, webhook_receiver.py) ───
WEBHOOK_PORT=8097
WEBHOOK_SECRET=
# Two-user fan-out: notify both a primary and a secondary user.
TELEGRAM_BOT_TOKEN_PRIMARY=
TELEGRAM_CHAT_ID_PRIMARY=
TELEGRAM_BOT_TOKEN_SECONDARY=
TELEGRAM_CHAT_ID_SECONDARY=

# ── Importer paths & tuning (importer.py / music_importer.py) ───────
# The importer runs where the NFS mount with qB downloads + libraries is visible.
LIB_AUDIOBOOKS=/mnt/nas/disk2/Abooks/Audiobooks
LIB_EBOOKS=/mnt/nas/disk2/Abooks/Ebooks
LIB_MUSIC=/mnt/nas/disk2/Music
QBIT_DL_CONTAINER=/downloads               # path qB reports
QBIT_DL_HOST=/mnt/nas/disk2/Torrents       # same mount as the importer sees
ABOOKS_CATEGORY=[Abooks]
MUSIC_CATEGORY=[Music]
IMPORTER_POLL_SEC=60
METADATA_FIX_RETRIES=12
METADATA_FIX_DELAY=5

# ── Music discovery batch (discovery/, optional) ────────────────────
MUSIC_MAX_INFLIGHT=20                       # cap on simultaneous grabs
MUSIC_MIN_FREE_GB=                          # disk guard; abort grabs below this
MEDIA_NAS_SSH=                              # ssh host for Bandcamp fire-and-forget
YTDLP_BIN=~/.local/bin/yt-dlp
# MUSIC_TARGETS / MUSIC_RESULTS override discovery/*.json paths (default: alongside scripts)
